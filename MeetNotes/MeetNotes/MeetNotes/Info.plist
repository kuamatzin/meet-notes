<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>SUPublicEDKey</key>
    <string>REPLACE_WITH_YOUR_SPARKLE_PUBLIC_ED_KEY</string>
    <key>SUFeedURL</key>
    <string>https://raw.githubusercontent.com/kuamatzin/meet-notes/main/appcast.xml</string>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>meet-notes needs microphone access to capture and transcribe meeting audio.</string>
    <key>NSAudioCaptureUsageDescription</key>
    <string>meet-notes needs to capture system audio to transcribe your meetings.</string>
</dict>
</plist>
